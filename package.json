{
  "name": "dnf-auto-fire",
  "private": true,
  "version": "0.3.3",
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build",
    "build:web": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src vite.config.ts --type-aware && eslint src vite.config.ts",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt --check src",
    "encoding:check": "node scripts/check-encoding.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm encoding:check",
    "rust:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:build": "cargo build --manifest-path src-tauri/Cargo.toml",
    "rust:build:release": "cargo build --manifest-path src-tauri/Cargo.toml --release",
    "rust:lint": "pnpm rust:clippy && pnpm rust:fmt:check",
    "test": "pnpm rust:test",
    "check:all": "pnpm check && pnpm rust:lint && pnpm rust:test",
    "ci": "pnpm check:all",
    "clean": "rm -rf node_modules dist src-tauri/target",
    "clean:dist": "rm -rf dist src-tauri/target",
    "clean:deps": "rm -rf node_modules src-tauri/target"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tauri-apps/cli": "^2.9.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.25",
    "globals": "^16.5.0",
    "oxfmt": "^0.18.0",
    "oxlint": "^1.32.0",
    "oxlint-tsgolint": "^0.18.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7"
  }
}